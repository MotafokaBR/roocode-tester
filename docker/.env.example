# Application port (host)
APP_PORT=8080

# OIDC Configuration
OIDC_CLIENT_ID=alias-forwarder
OIDC_CLIENT_SECRET=change-me-to-your-oidc-secret
OIDC_ISSUER_URI=https://auth.example.com/realms/main

# MXroute API URL (if different from default)
MXROUTE_API_URL=https://mail.mxrouting.net

# Logging
LOG_LEVEL=INFO

# Domain (for reverse proxy configs)
APP_DOMAIN=alias.example.com
